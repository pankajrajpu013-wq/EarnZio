## ☁️ Firebase Security Rules

```javascript
// Firestore Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // Users: read all, write own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Posts: read all, create if auth, update own
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // for likes
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // Comments: read all, write if auth
    match /posts/{postId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Notifications: read/write own only
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}

// Storage Rules
service firebase.storage {
  match /b/{bucket}/o {
    match /posts/{userId}/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // 10MB limit
        && request.resource.contentType.matches('image/.*');
    }
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }
  }
}
```

