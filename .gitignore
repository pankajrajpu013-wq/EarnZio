## 🪙 Coin Service (services/coin_service.dart)

```dart
import 'package:cloud_firestore/cloud_firestore.dart';

class CoinService {
  final FirebaseFirestore _db = FirebaseFirestore.instance;

  // Add coins to user
  Future<void> addCoins(String userId, int amount, String reason) async {
    await _db.collection('users').doc(userId).update({
      'coins': FieldValue.increment(amount),
    });
  }

  // Award like coins (with spam protection)
  Future<bool> awardLike(String postId, String likerId, String postOwnerId) async {
    if (likerId == postOwnerId) return false; // can't like own post

    final postRef = _db.collection('posts').doc(postId);
    final postDoc = await postRef.get();
    final likes = List<String>.from(postDoc.data()?['likedBy'] ?? []);

    if (likes.contains(likerId)) return false; // already liked

    // Batch write for atomicity
    final batch = _db.batch();
    batch.update(postRef, {
      'likesCount': FieldValue.increment(1),
      'likedBy': FieldValue.arrayUnion([likerId]),
    });
    batch.update(_db.collection('users').doc(postOwnerId), {
      'coins': FieldValue.increment(1),
    });
    await batch.commit();
    return true;
  }

  // Award comment coins
  Future<void> awardComment(String commenterId, String postOwnerId) async {
    if (commenterId == postOwnerId) return;
    await _db.collection('users').doc(postOwnerId).update({
      'coins': FieldValue.increment(2),
    });
  }

  // Award follow coins
  Future<void> awardFollow(String followedUserId) async {
    await _db.collection('users').doc(followedUserId).update({
      'coins': FieldValue.increment(3),
    });
  }

  // Award post coins (with daily limit check)
  Future<bool> awardPost(String userId) async {
    final userRef = _db.collection('users').doc(userId);
    final userDoc = await userRef.get();
    final data = userDoc.data()!;

    final now = DateTime.now();
    final lastPostDate = (data['lastPostDate'] as Timestamp?)?.toDate();
    int postsToday = data['postsToday'] ?? 0;

    // Reset daily counter if new day
    if (lastPostDate == null || !_isSameDay(lastPostDate, now)) {
      postsToday = 0;
    }

    if (postsToday >= 20) return false; // daily limit reached

    await userRef.update({
      'coins': FieldValue.increment(10),
      'postsToday': postsToday + 1,
      'lastPostDate': FieldValue.serverTimestamp(),
    });
    return true;
  }

  bool _isSameDay(DateTime a, DateTime b) =>
      a.year == b.year && a.month == b.month && a.day == b.day;
}
```

