## 📸 Post Service (services/post_service.dart)

```dart
import 'dart:io';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:firebase_storage/firebase_storage.dart';
import 'package:uuid/uuid.dart';

class PostService {
  final FirebaseFirestore _db = FirebaseFirestore.instance;
  final FirebaseStorage _storage = FirebaseStorage.instance;

  // Upload image & create post
  Future<String?> createPost({
    required String userId,
    required String username,
    required String userPhotoUrl,
    required File imageFile,
    required String caption,
  }) async {
    try {
      final postId = const Uuid().v4();

      // Upload image to Firebase Storage
      final ref = _storage.ref().child('posts/$userId/$postId.jpg');
      await ref.putFile(imageFile);
      final imageUrl = await ref.getDownloadURL();

      // Create post document
      await _db.collection('posts').doc(postId).set({
        'postId': postId,
        'userId': userId,
        'username': username,
        'userPhotoUrl': userPhotoUrl,
        'imageUrl': imageUrl,
        'caption': caption,
        'likesCount': 0,
        'commentsCount': 0,
        'likedBy': [],
        'createdAt': FieldValue.serverTimestamp(),
      });

      return postId;
    } catch (e) { return null; }
  }

  // Real-time feed stream
  Stream<QuerySnapshot> getFeedStream() {
    return _db
        .collection('posts')
        .orderBy('createdAt', descending: true)
        .limit(30)
        .snapshots();
  }

  // Add comment
  Future<void> addComment(String postId, String userId, String username, String text) async {
    final commentId = const Uuid().v4();
    await _db.collection('posts').doc(postId).collection('comments').doc(commentId).set({
      'commentId': commentId,
      'userId': userId,
      'username': username,
      'text': text,
      'createdAt': FieldValue.serverTimestamp(),
    });
    await _db.collection('posts').doc(postId).update({
      'commentsCount': FieldValue.increment(1),
    });
  }

  // Follow / Unfollow
  Future<void> followUser(String followerId, String followingId) async {
    final docId = '${followerId}_$followingId';
    final ref = _db.collection('follows').doc(docId);
    final doc = await ref.get();

    final batch = _db.batch();
    if (doc.exists) {
      // Unfollow
      batch.delete(ref);
      batch.update(_db.collection('users').doc(followingId), {'followers': FieldValue.increment(-1)});
      batch.update(_db.collection('users').doc(followerId), {'following': FieldValue.increment(-1)});
    } else {
      // Follow
      batch.set(ref, {'followerId': followerId, 'followingId': followingId, 'createdAt': FieldValue.serverTimestamp()});
      batch.update(_db.collection('users').doc(followingId), {'followers': FieldValue.increment(1)});
      batch.update(_db.collection('users').doc(followerId), {'following': FieldValue.increment(1)});
    }
    await batch.commit();
  }

  // Get leaderboard
  Stream<QuerySnapshot> getLeaderboard() {
    return _db.collection('users').orderBy('coins', descending: true).limit(20).snapshots();
  }
}
```

